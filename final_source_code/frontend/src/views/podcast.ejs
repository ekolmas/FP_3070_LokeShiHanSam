<%- include("layout", { title, body: ` <h1>Podcast</h1>
    <p>Welcome ${username}</p>

    <p>
        <a href="/preferences">Edit preferences</a> |
        <a href="/logout">Logout</a>
    </p>

    <hr />

    <h2>Latest Podcast</h2>

    ${
    (!preloaded || preloaded.length === 0)
    ? `<p>No preloaded podcasts found</p>`
    : preloaded.map(p => `
    <div style="border:1px solid #ddd; padding:16px; border-radius:12px; margin-bottom:12px;">
        <h3>${p.podcast_title}</h3>
        <small>${p.created_at}</small>

        <div style="margin-top:10px;">
            <img src="${p.image_url}" style="width:400px;border-radius:12px;" />
        </div>

        <div style="margin-top:10px;">
            <audio controls style="width:100%;" src="${p.audio_path}"></audio>
        </div>

        <div style="margin-top:6px; font-size:14px; opacity:0.8;">
            Generation time: ${(p.generation_time / 1000).toFixed(1)} seconds
        </div>
    </div>
    `).join("")
    }

    <hr />


    <div style="border:1px solid #ddd; padding:16px; border-radius:12px;">
        <h2>Generate New AI Podcast</h2>

        <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
            <div id="spinner" style="
        width:18px; height:18px;
        border:3px solid rgba(0,0,0,0.2);
        border-top-color: rgba(0,0,0,0.7);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        display:none;"></div>

            <div>
                <div id="genStatus" style="font-weight:600;">Idle</div>
                <div style="font-size:14px; opacity:0.8;">
                    Timer: <span id="elapsed">0.0</span>s
                </div>
            </div>

            <div style="flex:1;"></div>
            <button id="startBtn">Generate</button>
        </div>

        <ul id="liveList" style="padding-left:18px; margin:0;"></ul>
    </div>

    <style>
        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>

    <script>
        (function () {
            var startBtn = document.getElementById('startBtn');
            var spinner = document.getElementById('spinner');
            var genStatus = document.getElementById('genStatus');
            var elapsedEl = document.getElementById('elapsed');
            var liveList = document.getElementById('liveList');

            // Initialise timer variables
            var timer = null;
            //timerTracker used to track start time, eventSource is the EventSource instance
            var timerTracker = 0;
            var eventSource = null;

            // Function purpose: starts a timer that updates the elapsed time every 100ms
            function startTimer() {
                timerTracker = performance.now();
                timer = setInterval(function () {
                    var secs = (performance.now() - timerTracker) / 1000;
                    elapsedEl.textContent = secs.toFixed(1);
                }, 100);
            }

            // Function purpose: stops the timer and resets the timer variable
            function stopTimer() {
                if (timer) clearInterval(timer);
                timer = null;
            }

            // Function purpose: updates the UI when generating starts or stops
            function setGeneratingUI(isGenerating) {
                spinner.style.display = isGenerating ? 'inline-block' : 'none';
                startBtn.disabled = isGenerating;
            }

            // Event listener for the start button click event which starts the podcast generation process
            startBtn.addEventListener('click', async function () {
                // Reset UI
                liveList.innerHTML = '';
                elapsedEl.textContent = '0.0';
                genStatus.textContent = 'Starting...';

                // set UI to generating state
                setGeneratingUI(true);
                // Start timer
                startTimer();

                // if existing event source, close before starting new one
                if (eventSource) { eventSource.close(); eventSource = null; }

                try {
                    // Make POST request to start podcast generation and get job ID
                    var resp = await fetch('/podcast/start', { method: 'POST' });
                    var data = await resp.json();

                    // if response not ok, show error and reset UI
                    if (!data.ok) {
                        genStatus.textContent = 'Error: ' + (data.error || 'Unknown error');
                        setGeneratingUI(false);
                        stopTimer();
                        return;
                    }

                    // Update status to generating
                    genStatus.textContent = 'Generating...';

                    // new EventSource that listens to server events for job ID
                    eventSource = new EventSource('/podcast/events/' + data.jobId);

                    // when message received, parse and update UI
                    eventSource.onmessage = function (ev) {
                        var msg = JSON.parse(ev.data);

                        // if podcast item is ready
                        if (msg.type === 'item_ready') {
                            var item = msg.item;
                            var src = item.audio_url || item.audio_path;

                            var li = document.createElement('li');
                            li.style.marginBottom = '10px';

                            li.innerHTML =
                                '<div style="font-weight:600;">' + (item.title || 'Untitled') + '</div>' +
                                '<audio controls style="width:100%;" src="' + src + '"></audio>';

                            liveList.appendChild(li);
                        }

                        // if generation done, update status, reset UI and close event source connection
                        if (msg.type === 'done') {
                            genStatus.textContent = 'Done!';
                            setGeneratingUI(false);
                            stopTimer();
                            eventSource.close();
                            eventSource = null;
                        }

                        // if error, show error message, reset UI and close event source connection
                        if (msg.type === 'error') {
                            genStatus.textContent = 'Error: ' + (msg.error || 'Unknown error');
                            setGeneratingUI(false);
                            stopTimer();
                            eventSource.close();
                            eventSource = null;
                        }
                    };

                    // if error event received, show error message, reset UI and close event source connection
                    eventSource.onerror = function () {
                        genStatus.textContent = 'Connection lost.';
                        setGeneratingUI(false);
                        stopTimer();
                        if (eventSource) eventSource.close();
                        eventSource = null;
                    };

                } catch (e) {
                    // catch any other errors and reset UI
                    genStatus.textContent = 'Error: ' + (e.message || String(e));
                    setGeneratingUI(false);
                    stopTimer();
                }
            });
        })();
    </script>
    `}) %>